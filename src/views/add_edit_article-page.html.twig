{% extends "layouts/base.html.twig" %}
{% block content %}
	<div>
		{% set array = {} %}
		{% for key, category in list_categories %}
			{% set array = array|merge({ (key): category.name.singular }) %}
		{% endfor %}

      {% set needs_page_title = page.index > 1 %}

		<section class="sectionBlock">
			<h1 class="title">
            {% if type == "add" %}
               Ajouter une page
            {% else %}
               Éditer la page ""
            {% endif %}
         </h1>
			<form action="" id="form" class="content" enctype="multipart/form-data" method="POST" data-form-schema-validation="article_page">
				<script type="text/schema" data-form-schema="article_page">
					return z.object({
                  {% if needs_page_title %}
                  title: z.string().min(1, {error: "{{ form_error_messages.title.empty|e('js')|raw }}" }),
                  {% endif %}
                  content: z.string().min(1, {error: "{{ form_error_messages.content.empty|e('js')|raw }}" }),
                  header: z.file()
                     .nullable()
                     .transform((file) => (file && file.size > 0 ? file : null))
                     .refine(
                           (file) => {
                              if (file === null) {
                                 return true;
                              }
                              return "{{ image_header_requirements.mimeTypes }}".split(",").includes(file?.type);
                           },
                           "{{ form_error_messages.header.invalidFormat|e('js')|raw }}"
                     )
                     .refine(
                           (file) => {
                              if (file === null) {
                                 return true;
                              }
                              return file?.size < {{ image_header_requirements.maxSize }};
                           },
                           "{{ form_error_messages.header.tooBig|e('js')|raw }}"
                     )
                     .refine((file) => {
                        if (file === null) {
                           return Promise.resolve(true);
                        }
                        return new Promise((resolve) => {
                              const reader = new FileReader();
                              reader.onload = (e) => {
                                 const img = new Image();
                                 img.onload = () => {
                                    const heightRatio = (img.height * 100) / 1920;
                                    const meetsDimensions = img.width >= 1920 && heightRatio >= 30;

                                    resolve(meetsDimensions);
                                 };
                                 img.src = e.target?.result;
                              };
                              reader.readAsDataURL(file);
                           })
                     }, "{{ form_error_messages.header.badDimensions|e('js')|raw }}")
               })
				</script>
				<ul class="alert error" role="alert" data-form-error="article_page">{% for error_message in form_error_messages_triggered %}<li>{{ error_message }}</li>{% endfor %}</ul>
				<p class="alert warning">Les champs avec * sont requis</p>

            {% if flash_message == "page_updated" %}
				   <p class="alert success">Page mise à jour.</p>
            {% endif %}
            <p>Article : <a href="./EditArticle.php?id_article={{ article.id_article }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></p>

				<div>
               <div class="inputContainer">
						<p class="label">Image d'en-tête</p>
						<div class="notes">
							<p class="title">Remarques :</p>
							<ul>
								<li>L'image doit être au format .jp(e)g</li>
								<li>L'image doit avoir une taille inférieure à 1 Mo. Vous pouvez utiliser le site <a href="https://squoosh.app/" target="_blank" rel="noopener noreferrer">https://squoosh.app/</a> pour réduire la taille de l'image</li>
								<li>L'image est celle qui s'affiche au début de votre page. Pour le contenu de votre page, il faut aller dans la partie <a href="#medias">médias</a></li>
								<li>L'image fournie doit avoir une largeur supérieure ou égale à 1920 pixels, avec une hauteur d'au moins 30% la largeur. Soit un ratio de 10 / 3</li>
							</ul>
						</div>
                  {% set page_header = page.header ? page.header : "./default_article_header.jpg" %}
						{% include "includes/input-file.html.twig" with {
                        "options": {
                           "label": "Sélectionner image",
                           "input_name": "header",
                           "default_image": page_header,
                           "mimeTypes": header_image_requirements.mimeTypes
                        }
                     }
                  %}
					</div>

					<div class="inputContainer">
						<label for="title">Titre{% if needs_page_title %}<span style="color: var(--danger-color);">*</span>{% endif %}</label>
                  {% if needs_page_title %}
						<p class="notes">Vous pouvez laisser ce champ vide pour la première page. Les titre et sous-titre de l'article seront repris à la place</p>
                  {% endif %}
                  <input type="text" name="title" id="title" value="{{ page.title }}" maxlength="100">
					</div>

               <div class="inputContainer">
						<label for="page-content">Contenu<span style="color: var(--danger-color);">*</span></label>
                  {% include "includes/text-editor_toolbar.html.twig" %}
                  <div class="articleContentPreviewWrapper" id="articleContentPreviewWrapper">
                     <textarea name="content" id="page-content" rows="15">{{ page.content }}</textarea>
                     <div id="previewZone" class="articleContentPreview"></div>
                  </div>

                  <p class="notes">L'aperçu automatique du formatage propre aux articles est simplifié. Pensez à visualiser un aperçu complet d'un article pour mieux évaluer sa mise en page</p>
                  <div class="switchContainer">
                     <label class="switch">
                        <input type="checkbox" id="auto_preview" />
                     </label>
                     <label for="auto_preview">Aperçu automatique</label>
                  </div>
					</div>
				</div>
			</form>
		</section>

      <section class="sectionBlock" id="medias">
         <h2 class="title">Médias</h2>
         <div class="content">
            <div class="notes">
               <p class="title">Remarques :</p>
               <ul>
                  <li>Les médias joints à une page d'article ne sont jamais affichés automatiquement. <b>Vous devez les intégrer à votre texte</b></li>
                  <li>Seuls les premiers médias (par ordre lexicographique) seront conservés si le total excède 13 uploads</li>
                  <li>Seuls les images au format .jp(e)g, .gif, .png d'une taille inférieure à 1 Mo sont autorisés. Et les vidéos au format .mp4, .webm d'une taille inférieure à 5 Mo</li>
               </ul>
            </div>
            <div class="dragAndDropUpload">
               <ul class="listUploads" data-preview-dropzone="page-medias"></ul>
               <div class="dropzone paused" data-upload-dropzone="page-medias">
                  <p class="text">Glissez-déposez vos médias</p>
                  <p class="text">ou</p>
                  <div class="buttons">
                     <label class="primaryButton">
                        {# <i class="icon-file-empty"></i> #}
                        Uploader une image ou un clip vidéo
                        <input
                           type="file"
                           accept="video/webm, image/jpeg, image/gif, video/mp4"
                           name="{{ name }}"
                           multiple
                           data-upload-input-dropzone="page-medias"
                        />
                     </label>
                     <button
                        type="button"
                        class="secondaryButton"
                        data-clipboard-upload="{{ name }}"
                     >
                        Coller depuis le presse-papier
                     </button>
                  </div>
               </div>
               <details class="listErrors" data-errors-dropzone="page-medias" hidden>
                  <summary>Liste erreurs <span data-nb-file-errors></span></summary>
                  <ul></ul>
               </details>
            </div>
         </div>
      </section>
		<div class="inputContainer row">
         <button type="submit" form="form" class="fit primaryButton">
            {{ type == "add" ? "Créer" : "Éditer" }} page
         </button>
         <button type="submit" form="form" class="fit secondaryButton" value="preview" name="preview">
            {{ type == "add" ? "Créer" : "Éditer" }} page et prévisualiser
         </button>
      </div>
	</div>

   <dialog class="modal" id="delete-media" data-modal="delete-media">
      <header class="header danger">
         <p class="title">Supprimer le média</p>
         <button class="closeModal" command="close" commandfor="delete-media">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
            </svg>
            Fermer
         </button>
      </header>

      <div class="content">
         <div class="alert error">
            Cette action est irréversible
         </div>
         <img src="" alt="">
         <footer class="footer">
            <button type="button" class="danger" id="delete-media-btn">Supprimer le média</button>
         </footer>
      </div>
	</dialog>

   <dialog class="modal large" id="preview-media" data-modal="preview-media">
      <header class="header">
         <p class="title">Prévisualisation</p>
         <button class="closeModal" command="close" commandfor="preview-media">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
            </svg>
            Fermer
         </button>
      </header>

      <figure class="content">
         <img src="" alt="" class="lightboxImg" loading="lazy">
         <figcaption class="imageLegend">
            Uploadé le <span data-date></span>
            (<a href="http://" target="_blank" rel="noopener noreferrer">Voir image en grand</a>)
         </figcaption>
      </figure>
	</dialog>

   <template data-template-id="page-media-item">
      <li class="droppedMedia">
         <div class="menuBar">
            <button title="Ajouter à la page" data-media-data type="button" class="secondaryButton extensibleButton small" command="show-modal" commandfor="integrate-media">
               <i class="icon-general_plus" ></i>
               <span>Ajouter à la page</span>
            </button>
            <button title="supprimer média" data-media-data command="show-modal" commandfor="delete-media" class="danger extensibleButton small" type="button">
               <i class="icon-general_trash"></i>
               <span>Supprimer image</span>
            </button>
         </div>
         <button class="media" type="button" command="show-modal" data-media-data commandfor="preview-media">
            <img src="" alt="">
         </button>
      </li>
   </template>

   {% include "includes/text-editor_dialogs.html.twig" %}
{% endblock %}
