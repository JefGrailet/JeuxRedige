<div class="categoriesContainer mainFooter">
	<ul class="listCategories">
		<li>
			<a href="?" class="prettyLink {{ current_category == " default" ? " active" }}">
				<span>Tout</span>
			</a>
		</li>
		{% for key, value in list_categories %}
			<li>
				<a href="/articles/{{ key }}" class="prettyLink {{ current_category == key ? " active" }} {{key}}" style="color: var(--article-{{ key }}-color)">
					<span>{{ value.name.plural }}</span>
				</a>
			</li>
		{% endfor %}
	</ul>
	<select class="dropdownPagination" data-dropdown-redirect>
		<option value="?" {{ current_category == " default" ? " selected" }}>Tout</option>
		{% for key, value in list_categories %}
			<option value="?article_category={{ key }}" {{ current_category == key ? " selected" }}>{{ value.name.plural }}</option>
		{% endfor %}
	</select>
	<a href="/SearchArticles.php" class="filterLink">
		<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="currentColor">
			<path d="M8.25 10.875a2.625 2.625 0 1 1 5.25 0 2.625 2.625 0 0 1-5.25 0Z"/>
			<path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm-1.125 4.5a4.125 4.125 0 1 0 2.338 7.524l2.007 2.006a.75.75 0 1 0 1.06-1.06l-2.006-2.007a4.125 4.125 0 0 0-3.399-6.463Z" clip-rule="evenodd"/>
		</svg>

		<span>Chercher</span>
	</a>
</div>
