<div class="categoriesContainer">
   <ul class="listCategories">
      <li>
         <a href="?" class="prettyLink {{ current_category == "default" ? " active" }}">
            <span>Tout</span>
         </a>
      </li>
      {% for key, value in list_categories %}
         <li>
            <a href="?article_category={{ key }}" class="prettyLink {{ current_category == key ? " active" }} {{key}}" style="color: var(--article-{{ key }}-color)">
               <span>{{ value.name }}</span>
            </a>
         </li>
      {% endfor %}
   </ul>
   <select class="dropdownCategories" data-dropdown-redirect>
      <option value="?" {{ current_category == " default" ? " selected" }}>Tout</option>
      {% for key, value in list_categories %}
         <option value="?article_category={{ key }}" {{ current_category == key ? " selected" }}>{{ value.name }}</option>
      {% endfor %}
   </select>
   <a href="./SearchArticles.php" class="filterLink">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="currentColor" class="size-6">
         <path fill-rule="evenodd" d="M3.792 2.938A49.069 49.069 0 0 1 12 2.25c2.797 0 5.54.236 8.209.688a1.857 1.857 0 0 1 1.541 1.836v1.044a3 3 0 0 1-.879 2.121l-6.182 6.182a1.5 1.5 0 0 0-.439 1.061v2.927a3 3 0 0 1-1.658 2.684l-1.757.878A.75.75 0 0 1 9.75 21v-5.818a1.5 1.5 0 0 0-.44-1.06L3.13 7.938a3 3 0 0 1-.879-2.121V4.774c0-.897.64-1.683 1.542-1.836Z" clip-rule="evenodd"/>
      </svg>
      <span>Filtrer</span>
   </a>
</div>
