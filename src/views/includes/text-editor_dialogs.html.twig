{# Sélectionner une vidéo Youtube #}
<dialog class="modal medium" id="integrate-yt-video" data-modal="integrate-yt-video">
	<header class="header">
		<p class="title">Importer une vidéo Youtube</p>
		<button class="closeModal" command="close" commandfor="integrate-yt-video" data-close-modal>
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
			</svg>
			Fermer
		</button>
	</header>

	<form class="content gridForm" method="dialog" data-form-schema-validation="youtube_video">
		<p class="alert warning full">Les champs avec * sont requis</p>
      <ul class="alert error full" role="alert" data-form-error="youtube_video"></ul>

		<script type="text/schema" data-form-schema="youtube_video">
			return z.object({
            yt_video: z.httpUrl()
               .refine((value) => {
                  if (!value) {
                     return true;
                  }
                  const youtubeRegex = /http(?:s?):\/\/www.youtube(?:\.com\/watch\?v=)([\w\-\_]*)(&(amp;)?‌​[\w\?‌​=]*)?/;
                  return youtubeRegex.test(value ?? "");
               }, 'Ceci n\'est pas une URL valide de vidéo Youtube, veuillez vous référer à l\'exemple plus bas')
         })
		</script>
		<div class="inputContainer row">
			<label for="yt_video">Lien YouTube<span style="color: var(--danger-color);">*</span></label>
			<input type="url" name="yt_video" id="yt_video"/>
         <p class="notes full">Vous devez mettez l'URL intégrale de la vidéo YouTube. Ex : <a href="https://www.youtube.com/watch?v=E4WlUXrJgy4" target="_blank">https://www.youtube.com/watch?v=E4WlUXrJgy4</a></p>
		</div>
      <div class="inputContainer row">
			<label for="ratio_video">Taille</label>
			<select name="ratio_video" id="ratio_video">
            <option value="default">Par défaut (480 x 270 pixels)</option>
            <option value="0.25">Ajustée à 25% de la largeur</option>
            <option value="0.5">Ajustée à 50% de la largeur</option>
            <option value="0.75">Ajustée à 75% de la largeur</option>
            <option value="1.0">Ajustée à 100% de la largeur</option>
         </select>
		</div>

		<div class="inputContainer">
			<input type="submit" class="fit primaryButton" value="Insérer">
		</div>
	</form>
</dialog>

{# Intégrer média depuis la bibliothèque #}
<dialog class="modal medium" id="integrate-media" data-modal="integrate-media">
	<header class="header">
		<p class="title">Personnaliser le média</p>
		<button class="closeModal" type="button" command="close" commandfor="integrate-media">
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
			</svg>
			Fermer
		</button>
	</header>

	<form class="content gridForm" method="dialog">
      <p class="alert warning full">Les champs avec * sont requis</p>
		<img src="" alt="" class="full">
      <input type="hidden" name="media_type">
      <video disablepictureinpicture controls autoplay muted class="full" poster="{{ logo_chargement }}">
         <source src="" type="">
      </video>
		<div class="inputContainer row">
			<label for="url">URL</label>
			<input type="text" readonly name="media_url"/>
		</div>
		<div class="inputContainer row">
			<label for="mediaFormat">Format</label>
			<select name="media_format" id="mediaFormat">
				<option value="mini">Miniature</option>
				<option value="1.0">Dimensions originales</option>
				<option value="0.5">Dimensions x0.5</option>
				<option value="1.5">Dimensions x1.5</option>
				<option value="2.0">Dimensions x2</option>
				<option value="3.0">Dimensions x3</option>
				<option value="5.0">Dimensions x5</option>
			</select>
		</div>

		<div class="inputContainer row">
			<label for="mediaFloating">Alignement</label>
			<select name="media_floating" id="mediaFloating">
				<option value="normal">Aucun</option>
				<option value="left">A gauche</option>
				<option value="right">A droite</option>
			</select>
		</div>

		<div class="inputContainer row">
         <label for="altText">Texte alternatif</label>
			<input type="text" name="img_alt" id="altText" maxlength="250" placeholder="Maximum 250 caractères"/>
			<p class="notes full">Le champ est limité à 250 caractères. Le texte alternatif permet, pour les images, un meilleur référencement. Il est préférable de ne rien mettre plutôt qu'un texte sans signification comme "image 1"</p>
		</div>

		<div class="inputContainer">
			<input type="submit" class="fit primaryButton" value="Insérer">
		</div>
	</form>
</dialog>

