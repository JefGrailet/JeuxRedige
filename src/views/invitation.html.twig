{% extends "layouts/base.html.twig" %}

{% block content %}
	<section class="sectionBlock">
		<h1 class="title">Inscription par parrainage</h2>
		<div class="content">
			<p>Créez votre compte sans confirmation supplémentaire et en disposant de toutes les 
fonctionnalités du forum grâce à votre invitation !</p>
			<form action="" class="loginForm" novalidate method="POST" data-form-schema-validation="signin_sponsor">
				<script type="text/schema" data-form-schema="signin_sponsor">
					return z.object({
						pseudo: z.string().min(1, {error: "Vous devez définir un mot de passe" }),
						newPwd: z.string()
							.min(6, {error: "Votre mot de passe est trop court, 6 caractères minimum" })
							.max(30, {error: "Votre mot de passe est trop long, 30 caractères maximum" })
							.regex(/^[a-zA-Z0-9_-]+$/, {
								message: "Caractères alphanumériques autorisés ainsi que \"-\" et \"_\"",
							})
						,
					})
				</script>
            <ul class="alert error" data-form-error="signin_sponsor">{% for error_message in form_error_messages_triggered %}<li>{{ error_message }}</li>{% endfor %}</ul>
			<div class="gridForm">
            <input type="hidden" name="redirection" value="{{ logInRedirection }}" />
				<div class="inputContainer">
					<label for="pseudo">Pseudo</label>
					<input type="text" style="flex-grow: 1" name="pseudo" id="pseudo">
				</div>
				<div class="inputContainer">
					<label for="password">Mot de passe</label>
					<input type="password" minlength="6" maxlength="30" style="flex-grow: 1" data-input-toggle-visibility name="newPwd" id="password">
					<p class="notes full">Caractères alphanumériques autorisés ainsi que "-" et "_". Minimum 6 caractères, maximum 30</p>
				</div>

				<div class="inputContainer">
					<input type="submit" class="fit primaryButton" name="sent" value="Créer mon compte">
				</div>
			</div>
			</form>
		</div>

	</section>
{% endblock %}
