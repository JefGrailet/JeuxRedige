{% extends "layouts/base.html.twig" %}

{% block content %}
	<div data-page="">
      <header class="topicSummary">
         <p class="subtitle">Sujet :</p>
         <h1 class="title">{{ topic.title }}</h1>
         <p class="extraInfos">Crée par {{ topic.author }} le {{ post.date|date("d/m/Y \\à H\\:i\\:s") }}</p>
         {# {{ dump(topic)}} #}
      </header>
		<ul class="listPosts">
			{% for post in list_posts %}
				<li class="post">
					<img src="{{ post.author.avatar }}" alt="Image de profil de {{ post.author.pseudo }}" class="postBlockAvatar">
					<div class="postBlockText">
						<header class="postBlockTextTop">
							<div class="postBlockTextTopLeftSide">
								<p class="postAuthor">
									<a href="{{ post.author.profileUrl }}" title="Accéder au profil de {{ post.author.pseudo }}">
										{{ post.author.pseudo }}
									</a>
								</p>
								<a href="{{ post.permalink }}" class="permalink">
									<p class="postInfos">
										<b>#{{ post.index }}</b>
										-
										<time datetime="{{ post.date }}">{{ post.date|date("d/m/Y \\à H\\:i\\:s") }}</time>
										<i class="icon-general_hyperlink" title="Lien permanent"></i>
									</p>
								</a>
							</div>
							<div class="postBlockTextTopRightCorner">
								<button class="getPostInteractions" data-id-post="{{ post.ID }}" data-get-post-interactions-btn data-likes="{{ post.nb_likes }}" data-dislikes="{{ post.nb_dislikes }}" title="{{ post.nb_likes }} J'aime, {{ post.nb_dislikes }} Je n'aime pas">
                        {# popovertarget="postInfo-{{ post.ID }}" #}
									<i class="postInteractions icon-general_info"></i>
								</button>
							</div>
						</header>
						<div class="contentWrapper">
							<p class="content">
								{{ post.content|raw }}
							</p>
						</div>
					</div>
					<div id="postInfo-{{ post.ID }}" class="window" popover="manual" data-has-been-loaded="false">
						<header class="header">
							<p>
								Interactions des utilisateurs avec le message #{{ post.ID }}
							</p>
							<button class="closePopover" popovertargetaction="hide" popovertarget="postInfo-{{ post.ID }}" type="button">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
								</svg>
								Fermer
							</button>
						</header>
						<div class="content" data-content></div>
					</div>
				</li>
			{% endfor %}
		</ul>
	</div>
{% endblock %}
